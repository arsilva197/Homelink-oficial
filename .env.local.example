# ─────────────────────────────────────────────────────────────
#  HomeLink — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── Supabase (required for real data) ─────────────────────────
# Get these from: https://supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Service role key — ONLY for server-side / admin operations.
# NEVER expose this key on the client (no NEXT_PUBLIC_ prefix).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-here

# ── Demo mode ─────────────────────────────────────────────────
# When NEXT_PUBLIC_SUPABASE_URL is empty or not set, the app
# falls back to mock data automatically (no Supabase needed).
#
# Set to "true" to force mock data even when Supabase is configured.
NEXT_PUBLIC_DEMO_MODE=false

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
